ETSY_API_KEY=
ETSY_SHARED_SECRET=
ETSY_REDIRECT_URI=http://localhost:8082/etsy/oauth/callback
ETSY_SCOPES=shops_r listings_r

TOKEN_ENCRYPTION_KEY=
SYNC_MAX_CONCURRENCY=2
SYNC_REQUEST_TIMEOUT=15s
