APP_ENV=development
HTTP_ADDR=:8082
FRONTEND_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_USER=stok_user
DB_PASSWORD=stok_password
DB_NAME=stock_etsy_db
DB_SSLMODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=1

AUTH_SERVICE_URL=http://localhost:8081
AUTH_SERVICE_REQUEST_TIMEOUT=5s

